# Copy to .env, .env.prod, or .env.staging and fill in values.
# Never commit real secrets.

# To generate secret keys:
# `python -c 'import secrets; print(secrets.token_urlsafe(64))'`

# --- Identity / UX ---
SITE_NAME=Jackfruit.co MedSim
SITE_ADMIN_EMAIL=admin@jkfrt.com

# --- Images / deployment ---
SERVER_IMAGE_TAG=staging
DB_IMAGE_TAG=18.2-alpine
PROXY_IMAGE_TAG=latest
REDIS_IMAGE_TAG=7.4.2-alpine
NGINX_CONF_DIR=/opt/SimWorks/nginx
DJANGO_UPSTREAM_HOST=server

# --- Django / security ---
DJANGO_DEBUG=False
DJANGO_LOG_LEVEL=INFO
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=staging.medsim.jkfrt.com
CSRF_TRUSTED_ORIGINS=https://staging.medsim.jkfrt.com
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

DJANGO_MIGRATE=1
DJANGO_CREATE_DEFAULT_ROLES=1
DJANGO_COLLECTSTATIC=1

# --- Database ---
POSTGRES_NAME=AppDatabase
POSTGRES_USER=appuser
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOSTNAME=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- OrchestrAI / OpenAI ---
ORCA_OPENAI_API_KEY=
ORCA_DEFAULT_MODEL=openai-responses:gpt-5-nano
ORCA_IDENTITY_STRIP_TOKENS=Patient
ORCA_MAX_ATTEMPTS=1

# --- Observability ---
LOGFIRE_API_KEY=

# --- Storage (optional) ---
# CLOUDFLARE_R2_BUCKET=
# CLOUDFLARE_R2_ENDPOINT=
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=

# --- OAuth (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# --- JWT (if used) ---
JWT_SECRET_KEY=
# JWT_ACCESS_TOKEN_LIFETIME=3600
# JWT_REFRESH_TOKEN_LIFETIME=604800