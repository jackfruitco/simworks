{
  "name": "simworks-tailwind",
  "private": true,
  "version": "0.10.2",
  "scripts": {
    "build:css": "tailwindcss -i ./SimWorks/static/css/tailwind.input.css -o ./SimWorks/static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./SimWorks/static/css/tailwind.input.css -o ./SimWorks/static/css/tailwind.css --watch",
    "build:css:docker": "mkdir -p /app/static/css && tailwindcss -i /app/SimWorks/static/css/tailwind.input.css -o /app/static/css/tailwind.css --minify",
    "watch:css:docker": "mkdir -p /app/static/css && tailwindcss -i /app/SimWorks/static/css/tailwind.input.css -o /app/static/css/tailwind.css --watch --poll"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
